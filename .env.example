# PhantomLink Configuration
# Copy this file to .env and adjust values

# --- Encryption ---
# Path to encryption key file (auto-generated if missing)
PHANTOM_KEY_PATH=~/.phantom_key

# --- Targets ---
# Comma-separated list of default target platforms
PHANTOM_DEFAULT_TARGETS=zapero,waegy,wha7

# --- Operation ---
# Default number of cycles per session
PHANTOM_CYCLES=3
# Delay between cycles (seconds)
PHANTOM_CYCLE_DELAY=15
# Maximum retry attempts per cycle
PHANTOM_MAX_RETRIES=3

# --- Tor ---
# Enable Tor routing (true/false)
PHANTOM_TOR_ENABLED=true
# Tor SOCKS proxy
PHANTOM_TOR_SOCKS=socks5h://127.0.0.1:9050
# Tor control port
PHANTOM_TOR_CONTROL_PORT=9051

# --- Browser ---
# Chrome DevTools Protocol endpoint
PHANTOM_CDP_HOST=127.0.0.1
PHANTOM_CDP_PORT=9222

# --- Exfiltration ---
# Auto-push logs to Git (true/false)
PHANTOM_AUTO_EXFIL=true

# --- Ghost Numbers ---
# Comma-separated country codes for number generation
PHANTOM_COUNTRIES=ng,za,ke,gh

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
PHANTOM_LOG_LEVEL=INFO

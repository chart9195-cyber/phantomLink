{
  "name": "phantomlink",
  "version": "1.0.0",
  "description": "Browser session snapshot utility",
  "main": "index.js",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.19"
  },
  "scripts": {
    "audit": "npm audit --audit-level=high",
    "verify": "node -e \"const b=require('@whiskeysockets/baileys'); console.log('Baileys OK:', Object.keys(b).length,'exports')\""
  }
}
